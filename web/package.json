{
  "name": "aperture-web",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "description": "Aperture MVP portal SPA (Phase 0 walking skeleton).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
